+    {
+        /* Interrupted during syscall exit. Rewind the exit and handle as inside syscall. */
+        TRACE_(seh)( "rewinding syscall exit due to SIGUSR1 (rip=0x%lx, rax=0x%lx)\n",
+                     (long)RIP_sig(ucontext), (long)RAX_sig(ucontext));
+        RAX_sig(ucontext) = (ULONG_PTR)frame->retval; /* Restore return value */
