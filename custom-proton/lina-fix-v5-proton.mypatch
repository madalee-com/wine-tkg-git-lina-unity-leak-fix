+        return;
+    }
+    else if (amd64_thread_data()->sigusr1_blocked)
+    {
+        /* Interrupted during a syscall that is accessing user context. */
+        TRACE_(seh)( "deferring SIGUSR1 during critical syscall (rip=0x%lx, blocked=%d)\n",
+                     (long)RIP_sig(ucontext), amd64_thread_data()->sigusr1_blocked);
