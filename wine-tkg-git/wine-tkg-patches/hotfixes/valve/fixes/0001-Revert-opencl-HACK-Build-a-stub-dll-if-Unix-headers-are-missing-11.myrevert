+}
+
+static NTSTATUS wrap_clGetPlatformIDs( void *args )
+{
+    struct clGetPlatformIDs_params *params = args;
+
+    if (params->num_platforms) *params->num_platforms = 0;
+    return CL_SUCCESS;
+}
