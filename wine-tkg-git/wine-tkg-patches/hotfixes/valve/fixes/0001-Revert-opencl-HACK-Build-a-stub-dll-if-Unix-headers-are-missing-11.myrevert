+static NTSTATUS wrap_clEnqueueWaitForEvents( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clEnqueueWriteBuffer( void *args )
+{
+    return CL_INVALID_OPERATION;
