From f3195627a81f54e86f31ed2c8dd0f37a6fa61338 Mon Sep 17 00:00:00 2001
From: Paul Gofman <pgofman@codeweavers.com>
Date: Wed, 23 Apr 2025 18:30:32 -0600
Subject: [PATCH] opencl: HACK: Build a stub dll if Unix headers are missing.

CW-Bug-Id: #25276
(cherry picked from commit f946d7c633088e7ee41da62dcbcb5a7480804d65)
---
 configure.ac                |   9 -
 dlls/opencl/unix_private.h  |   4 +
 dlls/opencl/unix_thunks.c   | 397 ++++++++++++++++++++++++++++++++++++
 dlls/opencl/unix_wrappers.c |  17 ++
 4 files changed, 418 insertions(+), 9 deletions(-)

diff --git a/configure.ac b/configure.ac
index 4f4850a4bf94..08579f3cc802 100644
--- a/configure.ac
+++ b/configure.ac
@@ -1453,15 +1453,6 @@ else
                      [enable_winex11_drv])
 fi
 
-dnl **** Check for OpenCL ****
-if test "$ac_cv_header_CL_cl_h" = "yes"
-then
-    AC_CHECK_LIB(OpenCL,clGetPlatformInfo,[AC_SUBST(OPENCL_LIBS,["-lOpenCL"])])
-fi
-WINE_NOTICE_WITH(opencl,[test "x$ac_cv_lib_OpenCL_clGetPlatformInfo" != xyes],
-                 [OpenCL ${notice_platform}development files not found, OpenCL won't be supported.],
-                 [enable_opencl])
-
 dnl **** Check for libpcap ****
 if test "$ac_cv_header_pcap_pcap_h" = "yes"
 then
diff --git a/dlls/opencl/unix_private.h b/dlls/opencl/unix_private.h
index 49ac2102dfc4..226f676868e3 100644
--- a/dlls/opencl/unix_private.h
+++ b/dlls/opencl/unix_private.h
@@ -38,8 +38,12 @@
 #define CL_USE_DEPRECATED_OPENCL_2_0_APIS
 #define CL_TARGET_OPENCL_VERSION 220
 #include <CL/cl.h>
+#define HAVE_OPENCL
 #elif defined(HAVE_OPENCL_OPENCL_H)
 #include <OpenCL/opencl.h>
+#define HAVE_OPENCL
+#else
+#include "opencl_types.h"
 #endif
 
 #include "unixlib.h"
diff --git a/dlls/opencl/unix_thunks.c b/dlls/opencl/unix_thunks.c
index 5de92f470940..bf0125722ebb 100644
--- a/dlls/opencl/unix_thunks.c
+++ b/dlls/opencl/unix_thunks.c
@@ -7,6 +7,7 @@
 #include "config.h"
 #include "unix_private.h"
 
+#ifdef HAVE_OPENCL
 #ifdef __APPLE__
 #pragma clang diagnostic push
 #pragma clang diagnostic ignored "-Wdeprecated-declarations"
@@ -573,6 +574,402 @@ static NTSTATUS wrap_clWaitForEvents( void *args )
 #pragma clang diagnostic pop
 #endif
 
+#else
+static NTSTATUS wrap_clCreateBuffer( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateCommandQueue( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateImage( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateImage2D( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateImage3D( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateKernel( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateKernelsInProgram( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
+static NTSTATUS wrap_clCreateProgramWithBinary( void *args )
+{
+    return CL_INVALID_OPERATION;
+}
+
